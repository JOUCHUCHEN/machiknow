<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LEGO 9868 SPM: Bow & Arrow - STEAM Project</title>
    
    <!-- 引入 Noto Sans TC 字體 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Noto Sans TC"', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <!-- 自訂 CSS -->
    <style>
        body { font-family: 'Noto Sans TC', sans-serif; }
        .custom-scroll::-webkit-scrollbar { width: 8px; }
        .custom-scroll::-webkit-scrollbar-track { background: #f8fafc; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 20px; }
        .custom-scroll::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
    </style>

    <!-- Import Maps: 讓瀏覽器可以直接載入 React 與 Lucide Icons -->
    <script type="importmap">
    {
        "imports": {
            "react": "https://esm.sh/react@18.2.0",
            "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
            "lucide-react": "https://esm.sh/lucide-react@0.292.0?deps=react@18.2.0"
        }
    }
    </script>

    <!-- Babel Standalone: 在瀏覽器中即時編譯 JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body class="bg-slate-50 h-screen overflow-hidden">
    <!-- React 應用的掛載點 -->
    <div id="root" class="h-full"></div>

    <!-- 應用程式主體程式碼 -->
    <script type="text/babel" data-type="module">
        import React from 'react';
        import { createRoot } from 'react-dom/client';
        import { 
          Youtube, ExternalLink, AlertCircle, Lightbulb, Rocket, PlayCircle
        } from 'lucide-react';

        // --- 共用元件：廣告版位 ---
        const AdBanner = ({ format = 'horizontal', className = "" }) => (
          <div className={`relative flex items-center justify-center bg-gray-100 border-2 border-dashed border-gray-300 text-gray-400 rounded-lg overflow-hidden ${format === 'horizontal' ? 'w-full h-20 my-2' : 'w-full aspect-square max-h-[250px] my-4'} ${className}`}>
            <span className="absolute top-1 right-2 text-[10px] bg-gray-200 text-gray-500 px-1 rounded uppercase tracking-tighter font-bold">AD Space</span>
            <p className="font-semibold text-xs">{format === 'horizontal' ? '728 x 90' : '300 x 250'}</p>
          </div>
        );

        // --- Main App Component ---
        function SteamVideoPage() {
          const videoId = "ieDNvJNf0ag";
          const youtubeUrl = `https://www.youtube.com/watch?v=${videoId}`;

          return (
            <div className="h-full flex flex-col font-sans">
                {/* 獨立模組標頭 */}
                <header className="bg-white shadow-sm py-4 px-6 flex items-center justify-between z-10 shrink-0">
                    <div className="flex items-center gap-3">
                        <Rocket className="text-indigo-600" size={28} />
                        <h1 className="text-xl font-black text-slate-800 tracking-tight">STEAM Learning Module</h1>
                    </div>
                </header>

              <main className="flex-1 p-6 max-w-6xl mx-auto w-full flex flex-col overflow-y-auto custom-scroll">
                
                {/* Header 區塊：移除原本的回首頁按鈕 */}
                <div className="mb-8 pl-2">
                    <h2 className="text-3xl font-black text-gray-900 tracking-tight leading-none mb-2">LEGO 9868 SPM: Bow & Arrow</h2>
                    <p className="text-sm text-gray-400 font-bold tracking-widest uppercase opacity-80 flex items-center gap-2">
                        <PlayCircle size={16} /> STEAM Project Learning • Creative Engineering Design
                    </p>
                </div>

                {/* Video Frame */}
                <div className="bg-black rounded-[3rem] overflow-hidden shadow-2xl relative group aspect-video mx-auto w-full max-w-5xl border-[12px] border-white">
                  <iframe 
                    className="w-full h-full"
                    src={`https://www.youtube-nocookie.com/embed/${videoId}?rel=0&showinfo=0&modestbranding=1`} 
                    title="LEGO 9868 SPM: Bow & Arrow"
                    frameBorder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                    referrerPolicy="no-referrer-when-downgrade"
                    allowFullScreen
                  ></iframe>
                </div>

                {/* Error State Warning */}
                <div className="mt-8 flex flex-col items-center gap-3">
                  <div className="flex items-center gap-2 text-rose-500 text-[11px] font-black uppercase tracking-[0.2em] opacity-80">
                    <AlertCircle size={14} className="stroke-[3]" /> Playback Error?
                  </div>
                  <a 
                    href={youtubeUrl} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    className="flex items-center gap-3 text-base font-black text-white px-10 py-4 bg-rose-500 hover:bg-rose-600 rounded-full shadow-2xl shadow-rose-200 transition-all active:scale-95 group"
                  >
                    <Youtube size={22} className="group-hover:scale-110 transition-transform" /> 
                    Open in YouTube Player <ExternalLink size={18} />
                  </a>
                </div>

                {/* Info Area */}
                <div className="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-8 pb-12">
                  <div className="lg:col-span-2 bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm flex flex-col">
                     <h3 className="font-black text-xl mb-4 flex items-center gap-3 text-indigo-600 uppercase tracking-tighter">
                       <Lightbulb className="text-indigo-400" size={24} /> Project Overview
                     </h3>
                     <p className="text-gray-500 leading-loose text-base font-medium">
                       In this lesson, we will learn how to build a fully functional toy bow and arrow using Lego 9686 set! Through hands-on practice, students will experience basic concepts of physical tension, mechanical principles, and engineering structures, turning creativity into a physical masterpiece.
                     </p>
                  </div>
                  
                  {/* Ad Box */}
                  <div className="flex items-center justify-center p-2">
                     <AdBanner format="square" className="!my-0 w-full h-full min-h-[250px] !max-h-none" />
                  </div>
                </div>
              </main>
            </div>
          );
        }

        // Render the App
        const root = createRoot(document.getElementById('root'));
        root.render(<SteamVideoPage />);
    </script>
</body>
</html>
